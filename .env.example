# StorePilot Environment Variables
# Copy this file to .env.local and fill in your Supabase credentials

# Supabase Project URL
# Find this in your Supabase dashboard: Project Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anonymous Key (safe for client-side, has RLS policies applied)
# Find this in your Supabase dashboard: Project Settings > API > Project API keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (server-side only, bypasses RLS)
# ⚠️ NEVER expose this to the browser/client
# Find this in your Supabase dashboard: Project Settings > API > Project API keys > service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
